# Oura Ring OAuth credentials
# Register an app at https://cloud.ouraring.com/personal-access-tokens
OURA_CLIENT_ID=your_client_id
OURA_CLIENT_SECRET=your_client_secret
OURA_REDIRECT_URI=http://localhost:8080/callback

# Populated automatically by auth.py after first login — do not set manually
OURA_ACCESS_TOKEN=
OURA_REFRESH_TOKEN=

# Anthropic API key for AI-generated summaries
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key
